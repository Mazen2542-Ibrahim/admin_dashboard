# Database
DATABASE_URL=postgresql://admin:password@localhost:5432/admin_db

# Authentication (better-auth)
# Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-with-a-random-32-plus-char-secret
BETTER_AUTH_URL=http://localhost:3000

# Encryption key for SMTP passwords (AES-256 = 32 bytes = 64 hex chars)
# Generate: openssl rand -hex 32
ENCRYPTION_KEY=replace-with-64-char-hex-string

# App URL (used by auth-client and email links)
NEXT_PUBLIC_APP_URL=http://localhost:3000
